<section class="page-heading">
  <p class="eyebrow">Cellar</p>
  <h1>Products</h1>
  <p>Beer catalog, pour pricing, stock counts, and taproom availability.</p>
</section>

<section class="table-panel" aria-labelledby="productsTableTitle">
  <div class="section-header">
    <div>
      <p class="eyebrow">Inventory</p>
      <h2 id="productsTableTitle">Product List</h2>
    </div>
  </div>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Beer</th>
          <th scope="col">Style</th>
          <th scope="col">Price</th>
          <th scope="col">Stock</th>
          <th scope="col">Availability</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        {{#if products.length}}
          {{#each products}}
          <tr>
            <td class="numeric">#{{productID}}</td>
            <td><strong>{{productName}}</strong></td>
            <td>{{beerType}}</td>
            <td class="numeric">{{formatMoney beerPrice}}</td>
            <td class="numeric">{{productInStock}}</td>
            <td>
              {{#if currentlyAvailable}}
                <span class="badge badge-success">Available</span>
              {{else}}
                <span class="badge badge-muted">Unavailable</span>
              {{/if}}
            </td>
            <td>
              <form method="POST" action="/products/delete" onsubmit="return confirm('Delete this product and related order items?');">
                <input type="hidden" name="delete_product_id" value="{{productID}}">
                <button class="button button-danger button-compact" type="submit">Delete</button>
              </form>
            </td>
          </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="7" class="empty-state">No products have been added yet.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>

<section class="action-grid" aria-label="Product actions">
  <form class="form-panel" id="create_product_form" method="POST" action="/products/add">
    <div class="section-header">
      <div>
        <p class="eyebrow">New beer</p>
        <h2>Create Product</h2>
      </div>
    </div>

    <div class="form-grid">
      <label>
        <span>Name</span>
        <input type="text" name="productName" id="productName" required>
      </label>

      <label>
        <span>Beer Type</span>
        <input type="text" name="beerType" id="beerType" required>
      </label>

      <label>
        <span>Price</span>
        <input type="number" step="0.01" min="0" name="beerPrice" id="beerPrice" required>
      </label>

      <label>
        <span>Stock Quantity</span>
        <input type="number" min="0" name="productInStock" id="productInStock" required>
      </label>

      <label>
        <span>Available</span>
        <select name="currentlyAvailable" id="createCurrentlyAvailable" required>
          <option value="" disabled selected>Select availability</option>
          <option value="1">Yes</option>
          <option value="0">No</option>
        </select>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Add Product</button>
    </div>
  </form>

  <form class="form-panel" id="update_product_form" method="POST" action="/products/update">
    <div class="section-header">
      <div>
        <p class="eyebrow">Existing beer</p>
        <h2>Update Product</h2>
      </div>
    </div>

    <div class="form-grid">
      <label class="form-wide">
        <span>Product</span>
        <select name="productID" id="updateProductID" required>
          <option value="" disabled selected>Select a product</option>
          {{#each products}}
          <option value="{{this.productID}}"
                  data-name="{{this.productName}}"
                  data-type="{{this.beerType}}"
                  data-price="{{this.beerPrice}}"
                  data-stock="{{this.productInStock}}"
                  data-available="{{this.currentlyAvailable}}">
            #{{this.productID}} - {{this.productName}}
          </option>
          {{/each}}
        </select>
      </label>

      <label>
        <span>Name</span>
        <input type="text" name="productName" id="updateProductName">
      </label>

      <label>
        <span>Beer Type</span>
        <input type="text" name="beerType" id="updateBeerType">
      </label>

      <label>
        <span>Price</span>
        <input type="number" step="0.01" min="0" name="beerPrice" id="updateBeerPrice">
      </label>

      <label>
        <span>Stock Quantity</span>
        <input type="number" min="0" name="productInStock" id="updateProductInStock">
      </label>

      <label>
        <span>Available</span>
        <select name="currentlyAvailable" id="updateCurrentlyAvailable">
          <option value="" disabled>Select availability</option>
          <option value="1">Yes</option>
          <option value="0">No</option>
        </select>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Update Product</button>
    </div>
  </form>
</section>

<script>
document.getElementById('updateProductID').addEventListener('change', function() {
  const option = this.selectedOptions[0];
  document.getElementById('updateProductName').value = option.dataset.name || "";
  document.getElementById('updateBeerType').value = option.dataset.type || "";
  document.getElementById('updateBeerPrice').value = option.dataset.price || "";
  document.getElementById('updateProductInStock').value = option.dataset.stock || "";
  document.getElementById('updateCurrentlyAvailable').value = option.dataset.available || "";
});
</script>
