<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>BrewLogic POS</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header class="app-header">
        <a class="brand" href="/" aria-label="BrewLogic home">
            <span class="brand-mark">BL</span>
            <span>
                <span class="brand-name">BrewLogic</span>
                <span class="brand-subtitle">Brewery POS</span>
            </span>
        </a>

        <nav class="primary-nav" aria-label="Primary navigation">
            <a class="{{navActive "/" currentPath}}" href="/">Dashboard</a>
            <a class="{{navActive "/clients" currentPath}}" href="/clients">Clients</a>
            <a class="{{navActive "/products" currentPath}}" href="/products">Products</a>
            <a class="{{navActive "/categories" currentPath}}" href="/categories">Categories</a>
            <a class="{{navActive "/salesorders" currentPath}}" href="/salesorders">Orders</a>
            <a class="{{navActive "/orderitems" currentPath}}" href="/orderitems">Line Items</a>
        </nav>

        <form class="reset-form" method="POST" action="/reset" onsubmit="return confirm('Reset demo data? This will replace the current database contents.');">
            {{#if resetEnabled}}
                {{#if resetTokenConfigured}}
                    <input
                        class="reset-token-input"
                        type="password"
                        name="resetToken"
                        autocomplete="off"
                        placeholder="Reset token"
                        aria-label="Reset token"
                    >
                {{/if}}
                <button class="reset-link" type="submit">Reset demo data</button>
            {{else}}
                <button class="reset-link" type="submit" disabled>Reset unavailable</button>
                <span class="reset-note">Set BREWLOGIC_RESET_TOKEN in production to enable.</span>
            {{/if}}
        </form>
    </header>

    <main class="app-main">
        {{#if databaseError}}
        <div class="status-banner" role="status">{{databaseError}}</div>
        {{/if}}
        {{{body}}}
    </main>
</body>
</html>
