<section class="page-heading">
  <p class="eyebrow">Cart</p>
  <h1>Order Items</h1>
  <p>Beer lines attached to existing sales orders with quantity, price, and generated totals.</p>
</section>

<section class="table-panel" aria-labelledby="itemsTableTitle">
  <div class="section-header">
    <div>
      <p class="eyebrow">Line items</p>
      <h2 id="itemsTableTitle">Order Item List</h2>
    </div>
  </div>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th scope="col">Item</th>
          <th scope="col">Order</th>
          <th scope="col">Beer</th>
          <th scope="col">Style</th>
          <th scope="col">Qty</th>
          <th scope="col">Unit Price</th>
          <th scope="col">Line Total</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        {{#if orderitems.length}}
          {{#each orderitems}}
          <tr>
            <td class="numeric">#{{orderItemID}}</td>
            <td class="numeric">#{{orderID}}</td>
            <td><strong>{{productName}}</strong></td>
            <td>{{beerType}}</td>
            <td class="numeric">{{orderQty}}</td>
            <td class="numeric">{{formatMoney unitPrice}}</td>
            <td class="numeric">{{formatMoney lineTotal}}</td>
            <td>
              <form method="POST" action="/orderitems/delete" onsubmit="return confirm('Delete this line item?');">
                <input type="hidden" name="delete_orderitem_id" value="{{orderItemID}}">
                <button class="button button-danger button-compact" type="submit">Delete</button>
              </form>
            </td>
          </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="8" class="empty-state">No order items have been added yet.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>

<section class="action-grid" aria-label="Order item actions">
  <form class="form-panel" id="create_orderitem_form" method="POST" action="/orderitems/add">
    <div class="section-header">
      <div>
        <p class="eyebrow">Add beer line</p>
        <h2>Add Product to Order</h2>
      </div>
    </div>

    <div class="form-grid">
      <label class="form-wide">
        <span>Order</span>
        <select name="orderID" id="orderID" required>
          <option value="" disabled selected>Select order</option>
          {{#each salesorders}}
          <option value="{{this.orderID}}">#{{this.orderID}} - {{formatDate this.orderDate}} - {{this.clientName}}</option>
          {{/each}}
        </select>
      </label>

      <label class="form-wide">
        <span>Product</span>
        <select name="productID" id="productID" required>
          <option value="" disabled selected>Select product</option>
          {{#each products}}
          <option value="{{this.productID}}" data-price="{{this.beerPrice}}">
            #{{this.productID}} - {{this.productName}} ({{this.beerType}})
          </option>
          {{/each}}
        </select>
      </label>

      <label>
        <span>Quantity</span>
        <input type="number" min="1" name="orderQty" id="orderQty" required>
      </label>

      <label>
        <span>Unit Price</span>
        <input type="number" step="0.01" min="0" name="unitPrice" id="unitPrice" required>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Add Item</button>
    </div>
  </form>

  <form class="form-panel" id="update_orderitem_form" method="POST" action="/orderitems/update">
    <div class="section-header">
      <div>
        <p class="eyebrow">Revise beer line</p>
        <h2>Update Order Item</h2>
      </div>
    </div>

    <div class="form-grid">
      <label class="form-wide">
        <span>Order Item</span>
        <select name="orderItemID" id="updateOrderItemID" required>
          <option value="" disabled selected>Select an item</option>
          {{#each orderitems}}
          <option value="{{this.orderItemID}}"
                  data-qty="{{this.orderQty}}"
                  data-price="{{this.unitPrice}}">
            #{{this.orderItemID}} - {{this.productName}} on order #{{this.orderID}}
          </option>
          {{/each}}
        </select>
      </label>

      <label>
        <span>Quantity</span>
        <input type="number" min="1" name="orderQty" id="updateOrderQty">
      </label>

      <label>
        <span>Unit Price</span>
        <input type="number" step="0.01" min="0" name="unitPrice" id="updateUnitPrice">
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Update Item</button>
    </div>
  </form>
</section>

<script>
document.getElementById('productID').addEventListener('change', function() {
  const option = this.selectedOptions[0];
  document.getElementById('unitPrice').value = option.dataset.price || "";
});

document.getElementById('updateOrderItemID').addEventListener('change', function() {
  const option = this.selectedOptions[0];
  document.getElementById('updateOrderQty').value = option.dataset.qty || "";
  document.getElementById('updateUnitPrice').value = option.dataset.price || "";
});
</script>
