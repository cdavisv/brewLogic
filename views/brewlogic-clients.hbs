<section class="page-heading">
  <p class="eyebrow">Accounts</p>
  <h1>Clients</h1>
  <p>Customer and vendor records tied to BrewLogic categories.</p>
</section>

<section class="table-panel" aria-labelledby="clientsTableTitle">
  <div class="section-header">
    <div>
      <p class="eyebrow">Directory</p>
      <h2 id="clientsTableTitle">Client List</h2>
    </div>
  </div>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Name</th>
          <th scope="col">Category</th>
          <th scope="col">Email</th>
          <th scope="col">Phone</th>
          <th scope="col">Address</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        {{#if clients.length}}
          {{#each clients}}
          <tr>
            <td class="numeric">#{{clientID}}</td>
            <td>
              <strong>{{firstName}} {{lastName}}</strong>
            </td>
            <td><span class="badge">{{categoryName}}</span></td>
            <td><a class="table-link" href="mailto:{{email}}">{{email}}</a></td>
            <td>{{phoneNumber}}</td>
            <td>{{address}}</td>
            <td>
              <form method="POST" action="/clients/delete" onsubmit="return confirm('Delete this client and related sales orders?');">
                <input type="hidden" name="delete_client_id" value="{{clientID}}">
                <button class="button button-danger button-compact" type="submit">Delete</button>
              </form>
            </td>
          </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="7" class="empty-state">No clients have been added yet.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>

<section class="action-grid" aria-label="Client actions">
  <form class="form-panel" id="create_client_form" method="POST" action="/clients/add">
    <div class="section-header">
      <div>
        <p class="eyebrow">New account</p>
        <h2>Create Client</h2>
      </div>
    </div>

    <div class="form-grid">
      <label>
        <span>First Name</span>
        <input type="text" name="firstName" id="firstName" autocomplete="given-name" required>
      </label>

      <label>
        <span>Last Name</span>
        <input type="text" name="lastName" id="lastName" autocomplete="family-name">
      </label>

      <label>
        <span>Email</span>
        <input type="email" name="email" id="email" autocomplete="email" required>
      </label>

      <label>
        <span>Phone Number</span>
        <input type="text" name="phoneNumber" id="phoneNumber" autocomplete="tel">
      </label>

      <label class="form-wide">
        <span>Address</span>
        <input type="text" name="address" id="address" autocomplete="street-address">
      </label>

      <label>
        <span>Category</span>
        <select name="categoryID" id="createCategoryID" required>
          <option value="" disabled selected>Select category</option>
          {{#each categories}}
          <option value="{{this.categoryID}}">{{this.categoryName}}</option>
          {{/each}}
        </select>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Add Client</button>
    </div>
  </form>

  <form class="form-panel" id="update_client_form" method="POST" action="/clients/update">
    <div class="section-header">
      <div>
        <p class="eyebrow">Existing account</p>
        <h2>Update Client</h2>
      </div>
    </div>

    <div class="form-grid">
      <label class="form-wide">
        <span>Client</span>
        <select name="clientID" id="clientID" required>
          <option value="" disabled selected>Select a client</option>
          {{#each clients}}
          <option value="{{this.clientID}}"
                  data-first="{{this.firstName}}"
                  data-last="{{this.lastName}}"
                  data-email="{{this.email}}"
                  data-phone="{{this.phoneNumber}}"
                  data-address="{{this.address}}"
                  data-category="{{this.categoryID}}">
            #{{this.clientID}} - {{this.firstName}} {{this.lastName}}
          </option>
          {{/each}}
        </select>
      </label>

      <label>
        <span>First Name</span>
        <input type="text" name="firstName" id="updateFirstName">
      </label>

      <label>
        <span>Last Name</span>
        <input type="text" name="lastName" id="updateLastName">
      </label>

      <label>
        <span>Email</span>
        <input type="email" name="email" id="updateEmail">
      </label>

      <label>
        <span>Phone Number</span>
        <input type="text" name="phoneNumber" id="updatePhoneNumber">
      </label>

      <label class="form-wide">
        <span>Address</span>
        <input type="text" name="address" id="updateAddress">
      </label>

      <label>
        <span>Category</span>
        <select name="categoryID" id="updateCategoryID">
          <option value="" disabled selected>Select category</option>
          {{#each categories}}
          <option value="{{this.categoryID}}">{{this.categoryName}}</option>
          {{/each}}
        </select>
      </label>
    </div>

    <div class="form-actions">
      <button class="button button-primary" type="submit">Update Client</button>
    </div>
  </form>
</section>

<script>
document.getElementById('clientID').addEventListener('change', function() {
  const option = this.selectedOptions[0];
  document.getElementById('updateFirstName').value = option.dataset.first || "";
  document.getElementById('updateLastName').value = option.dataset.last || "";
  document.getElementById('updateEmail').value = option.dataset.email || "";
  document.getElementById('updatePhoneNumber').value = option.dataset.phone || "";
  document.getElementById('updateAddress').value = option.dataset.address || "";
  document.getElementById('updateCategoryID').value = option.dataset.category || "";
});
</script>
